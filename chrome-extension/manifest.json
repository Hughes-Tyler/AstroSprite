{
  "manifest_version": 3,
  "name": "AstroSprite",
  "version": "1.0.0",
  "description": "An 8-bit astronaut that floats around every page you visit.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
